# Shared Environment Variables
# Copy this file to .env and fill in the values.
# Run 'node sync-env.js' to propagate these to all sub-applications.

# Backend Configuration
VITE_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase Configuration (Used in AI Legal Portal)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Ports (For reference and Gateway)
PORT_DASHBOARD=3002
PORT_AI_LEGAL=3001
PORT_MAPPING=5173
PORT_BARCODE=3000
PORT_COVERLETTER=5001
PORT_BACKEND=8000
