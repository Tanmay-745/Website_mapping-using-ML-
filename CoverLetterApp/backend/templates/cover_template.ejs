<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Envelope Print</title>
    <style>
        @page {
            size: 220mm 110mm;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 0;
            width: 220mm;
            height: 110mm;
            font-family: 'Segoe UI', Arial, sans-serif;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            background: #fff;
        }

        .envelope {
            width: 100%;
            height: 100%;
            position: relative;
            box-sizing: border-box;
            page-break-after: always;
            /* Ensure each envelope is on a new page */
            overflow: hidden;
        }

        /* Prevent empty page at the end of the PDF */
        .envelope:last-child {
            page-break-after: auto;
        }

        .header-section {
            position: absolute;
            top: 10mm;
            left: 20mm;
            right: 20mm;
            /* Allow it to span width */
        }

        .header-section img {
            height: 30mm;
            width: auto;
            max-width: 100%;
            object-fit: contain;
        }

        .to-section {
            position: absolute;
            top: 52mm;
            /* Increased gap to accommodate header and code */
            left: 20mm;
            width: 100mm;
            font-size: 11pt;
            font-weight: bold;
            color: black;
            line-height: 1.5;
        }

        .to-section .small {
            font-size: 10pt;
            font-weight: normal;
        }

        .barcode-wrapper {
            position: absolute;
            bottom: 15mm;
            left: 20mm;
            width: 85mm;
            text-align: left;
        }

        .barcode-wrapper img {
            width: 100%;
            height: 18mm;
            object-fit: contain;
        }

        .from-section {
            position: absolute;
            bottom: 12mm;
            left: 115mm;
            width: 90mm;
            font-size: 11pt;
            font-weight: bold;
            color: black;
            line-height: 1.4;
        }

        .from-section .small {
            font-size: 10pt;
            font-weight: normal;
        }

        .from-section .sender-item {
            display: flex;
            align-items: flex-start;
            gap: 2mm;
            margin-bottom: 1mm;
        }

        .sender-icon {
            width: 3.5mm;
            height: 3.5mm;
            margin-top: 0.5mm;
            flex-shrink: 0;
            color: #4b5563;
        }

        .code-section {
            position: absolute;
            top: 42mm;
            right: 20mm;
            font-size: 13pt;
            font-weight: bold;
            color: black;
        }

        .left-code-section {
            position: absolute;
            top: 42mm;
            left: 20mm;
            font-size: 13pt;
            font-weight: bold;
            color: black;
        }

        @media screen {
            body {
                background: #f0f0f0;
                height: auto;
            }

            .envelope {
                background: #fff;
                margin: 20px auto;
                box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
                page-break-after: auto;
            }
        }
    </style>
</head>

<body>
    <% if (typeof envelopes !=='undefined' && envelopes.length> 0) { %>
        <% envelopes.forEach(function(env) { %>
            <div class="envelope">
                <% if (typeof logoDataUri !=='undefined' && logoDataUri) { %>
                    <div class="header-section">
                        <img src="<%= logoDataUri %>" alt="Header Logo" />
                    </div>
                    <% } %>
                        <div class="left-code-section">
                            921-545-SP-NAF

                        </div>

                        <div class="to-section">
                            To: <%= env.name %> <br>
                                <% if (env.phone && env.phone.toString().trim() !=='' ) { %>
                                    Mobile No: <%= env.phone %><br>
                                        <% } %>
                                            <div class="small">
                                                <b>Address:</b>
                                                <%= env.address %>
                                            </div>
                        </div>

                        <div class="barcode-wrapper">
                            <img src="<%= env.barcode %>" alt="barcode">
                        </div>

                        <div class="from-section">
                            <div class="small">
                                <div><b>From:</b>
                                    <%= sender.from %>
                                </div>
                                <% if (sender.mobile) { %>
                                    <div><b>Mobile:</b>
                                        <%= sender.mobile %>
                                    </div>
                                    <% } %>
                                        <% if (sender.address) { %>
                                            <div><b>Address:</b>
                                                <%= sender.address %>
                                            </div>
                                            <% } %>
                            </div>
                        </div>

                        <div class="code-section">
                            CFMARC TRUST-196
                        </div>
            </div>
            <% }); %>
                <% } else { %>
                    <div style="padding: 20px;">No envelope data available.</div>
                    <% } %>
</body>

</html>